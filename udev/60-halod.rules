# HaloDaemon udev rules
#
# Install:
#   sudo cp 60-halod.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#
# Add your user to the required groups:
#   sudo usermod -aG input,i2c $USER
#   (log out and back in for changes to take effect)
#
# Group summary:
#   input  — USB HID devices (all USB peripherals below)
#   i2c    — SMBus I2C devices (ASUS/ENE DRAM and GPU RGB)

# ─── NZXT ─────────────────────────────────────────────────────────────────────

# NZXT Control Hub
KERNEL=="hidraw*", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="2022", TAG+="uaccess", GROUP="input", MODE="0660"

# NZXT Kraken X53/X63/X73
KERNEL=="hidraw*", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="2007", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="2014", TAG+="uaccess", GROUP="input", MODE="0660"
# NZXT Kraken Z53/63/73
KERNEL=="hidraw*", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="3008", TAG+="uaccess", GROUP="input", MODE="0660"
# NZXT Kraken Elite 2023
KERNEL=="hidraw*", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="300c", TAG+="uaccess", GROUP="input", MODE="0660"
# NZXT Kraken 2023
KERNEL=="hidraw*", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="300e", TAG+="uaccess", GROUP="input", MODE="0660"
# NZXT Kraken Elite RGB 2024
KERNEL=="hidraw*", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="3012", TAG+="uaccess", GROUP="input", MODE="0660"
# NZXT Kraken Plus 2024
KERNEL=="hidraw*", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="3014", TAG+="uaccess", GROUP="input", MODE="0660"

# USB device nodes for Kraken models with LCD panels (needed for libusb bulk transfers).
# The hidraw rules above only grant access to the HID interface; the LCD engine
# also opens the raw USB device via rusb for bulk OUT transfers.
SUBSYSTEM=="usb", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="3008", TAG+="uaccess", GROUP="input", MODE="0660"
SUBSYSTEM=="usb", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="300c", TAG+="uaccess", GROUP="input", MODE="0660"
SUBSYSTEM=="usb", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="300e", TAG+="uaccess", GROUP="input", MODE="0660"
SUBSYSTEM=="usb", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="3012", TAG+="uaccess", GROUP="input", MODE="0660"
SUBSYSTEM=="usb", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="3014", TAG+="uaccess", GROUP="input", MODE="0660"

# ─── Logitech ─────────────────────────────────────────────────────────────────

# Logitech Lightspeed Receiver (manages wireless G502 X Plus, G PRO X TKL)
KERNEL=="hidraw*", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c547", TAG+="uaccess", GROUP="input", MODE="0660"
# Logitech G502 X Plus (wired)
KERNEL=="hidraw*", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c095", TAG+="uaccess", GROUP="input", MODE="0660"
# Logitech G PRO X TKL (wired)
KERNEL=="hidraw*", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c352", TAG+="uaccess", GROUP="input", MODE="0660"
# Logitech G560 Gaming Speaker
KERNEL=="hidraw*", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="0a78", TAG+="uaccess", GROUP="input", MODE="0660"

# ─── Corsair ──────────────────────────────────────────────────────────────────

# Corsair K70 RGB MK.2 Low Profile
KERNEL=="hidraw*", ATTRS{idVendor}=="1b1c", ATTRS{idProduct}=="1b55", TAG+="uaccess", GROUP="input", MODE="0660"

# ─── Razer ────────────────────────────────────────────────────────────────────

# Razer Basilisk V3
KERNEL=="hidraw*", ATTRS{idVendor}=="1532", ATTRS{idProduct}=="0099", TAG+="uaccess", GROUP="input", MODE="0660"

# ─── SteelSeries ──────────────────────────────────────────────────────────────

# SteelSeries Arctis Nova Pro Wireless
KERNEL=="hidraw*", ATTRS{idVendor}=="1038", ATTRS{idProduct}=="12e0", TAG+="uaccess", GROUP="input", MODE="0660"
# SteelSeries Arctis Nova Pro X Wireless
KERNEL=="hidraw*", ATTRS{idVendor}=="1038", ATTRS{idProduct}=="12e5", TAG+="uaccess", GROUP="input", MODE="0660"

# ─── ASUS ─────────────────────────────────────────────────────────────────────

# ASUS Aura USB controllers (motherboard RGB headers)
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1866", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1867", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1872", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="18a3", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="18a5", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="18f3", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1939", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="19af", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1a30", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1a6c", TAG+="uaccess", GROUP="input", MODE="0660"
# ASUS X870E
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1aa6", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1b3b", TAG+="uaccess", GROUP="input", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1bed", TAG+="uaccess", GROUP="input", MODE="0660"

# ─── Philips ──────────────────────────────────────────────────────────────────

# Philips Evnia 49 Ultrawide — USB DDC-CI interface (via USB hub chip)
SUBSYSTEM=="usb", ATTRS{idVendor}=="2109", ATTRS{idProduct}=="8884", TAG+="uaccess", GROUP="input", MODE="0660"
# Philips Evnia 49 Ultrawide — Ambiglow rear LEDs (ENE Technology RGB controller)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0cf2", ATTRS{idProduct}=="b201", TAG+="uaccess", GROUP="input", MODE="0660"

# ─── uinput (key remapper / action executor) ──────────────────────────────────

# Grant write access to /dev/uinput for the key remapper's virtual input devices.
# Required for Wayland and headless operation (no X11 dependency).
KERNEL=="uinput", SUBSYSTEM=="misc", GROUP="input", MODE="0660", TAG+="uaccess"

# ─── SMBus / I2C (ASUS/ENE DRAM + GPU RGB) ────────────────────────────────────

# Grant I2C bus access for ENE SMBus RGB devices (DRAM sticks, GPU).
# User must be in the 'i2c' group: sudo usermod -aG i2c $USER
SUBSYSTEM=="i2c-dev", GROUP="i2c", MODE="0660"

# ─── hwmon PWM fan control ────────────────────────────────────────────────────

# Grant write access to hwmon PWM control files (pwmN, pwmN_enable) so the
# daemon can run without root. Covers nct6775, it87, and other SuperIO drivers.
# The shell glob expands pwm1..pwm7 and their _enable counterparts.
SUBSYSTEM=="hwmon", KERNEL=="hwmon[0-9]*", ATTR{name}=="nct6775", ACTION=="add", RUN{program}+="/bin/sh -c 'chmod a+w /sys%p/pwm[1-7] /sys%p/pwm[1-7]_enable 2>/dev/null; true'"
SUBSYSTEM=="hwmon", KERNEL=="hwmon[0-9]*", ATTR{name}=="nct6776", ACTION=="add", RUN{program}+="/bin/sh -c 'chmod a+w /sys%p/pwm[1-7] /sys%p/pwm[1-7]_enable 2>/dev/null; true'"
SUBSYSTEM=="hwmon", KERNEL=="hwmon[0-9]*", ATTR{name}=="nct6796", ACTION=="add", RUN{program}+="/bin/sh -c 'chmod a+w /sys%p/pwm[1-7] /sys%p/pwm[1-7]_enable 2>/dev/null; true'"
SUBSYSTEM=="hwmon", KERNEL=="hwmon[0-9]*", ATTR{name}=="nct6798", ACTION=="add", RUN{program}+="/bin/sh -c 'chmod a+w /sys%p/pwm[1-7] /sys%p/pwm[1-7]_enable 2>/dev/null; true'"
SUBSYSTEM=="hwmon", KERNEL=="hwmon[0-9]*", ATTR{name}=="nct6799", ACTION=="add", RUN{program}+="/bin/sh -c 'chmod a+w /sys%p/pwm[1-7] /sys%p/pwm[1-7]_enable 2>/dev/null; true'"
SUBSYSTEM=="hwmon", KERNEL=="hwmon[0-9]*", ATTR{name}=="it8686", ACTION=="add", RUN{program}+="/bin/sh -c 'chmod a+w /sys%p/pwm[1-7] /sys%p/pwm[1-7]_enable 2>/dev/null; true'"
SUBSYSTEM=="hwmon", KERNEL=="hwmon[0-9]*", ATTR{name}=="it8720", ACTION=="add", RUN{program}+="/bin/sh -c 'chmod a+w /sys%p/pwm[1-7] /sys%p/pwm[1-7]_enable 2>/dev/null; true'"
SUBSYSTEM=="hwmon", KERNEL=="hwmon[0-9]*", ATTR{name}=="it8728", ACTION=="add", RUN{program}+="/bin/sh -c 'chmod a+w /sys%p/pwm[1-7] /sys%p/pwm[1-7]_enable 2>/dev/null; true'"
