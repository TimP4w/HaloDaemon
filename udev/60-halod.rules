# HaloDaemon base udev rules
#
# Device-specific HID and USB rules are derived from installed plugin
# manifests. Print the complete assembled file with:
#
#   halod udev-rules
#
# Install or refresh it without running HaloDaemon as root:
#
#   halod udev-rules | sudo tee /etc/udev/rules.d/60-halod.rules >/dev/null
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger

# ─── uinput (key remapper / action executor) ──────────────────────────────────

# Grant write access to /dev/uinput for the key remapper's virtual input devices.
# Required for Wayland and headless operation.
# static_node=uinput creates the node (with the uaccess ACL) at boot even before
# the uinput module is loaded; opening it then autoloads the module.
KERNEL=="uinput", SUBSYSTEM=="misc", TAG+="uaccess", OPTIONS+="static_node=uinput"

# ─── hwmon PWM fan control ────────────────────────────────────────────────────

# Grant write access to pwm1..pwm7 and their optional _enable siblings,
# independent of the hwmon driver's chip name. These files are scoped to the
# `halod` group; uaccess is not usable because hwmon nodes have no seat
# association.
SUBSYSTEM=="hwmon", KERNEL=="hwmon[0-9]*", ACTION=="add|change", RUN{program}+="/bin/sh -c 'chgrp halod /sys%p/pwm[1-7] /sys%p/pwm[1-7]_enable 2>/dev/null; chmod g+w /sys%p/pwm[1-7] /sys%p/pwm[1-7]_enable 2>/dev/null; true'"
