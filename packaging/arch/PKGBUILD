# Maintainer: Timucin Besken <beskent@gmail.com>
pkgname=halod
pkgver=0.9.0
pkgrel=1
plugin_commit=7c4aaa06c34983e97f49e960b9a663b323509c90
pkgdesc="Peripheral control daemon (fan curves, RGB, LCD, audio EQ, DPI)"
arch=('x86_64')
url="https://github.com/TimP4w/HaloDaemon"
license=('GPL-3.0-or-later')
depends=('hidapi' 'libusb' 'pipewire' 'systemd-libs' 'wayland' 'libxkbcommon'
         'libglvnd' 'dbus')
makedepends=('rust' 'cargo' 'clang' 'pkgconf' 'git')
optdepends=('ffmpeg: LCD video playback'
            'nvidia-utils: GPU temperature readout via nvidia-smi'
            'i2c-tools: SMBus/DRAM + GPU RGB diagnostics')
install="$pkgname.install"
# Pin to an immutable commit, not the mutable `#tag=v$pkgver`: a tag can be force-moved after publication so "v$pkgver" is not reproducible, whereas `#commit=` locks makepkg to a fixed git object. 'SKIP' is still correct because makepkg cannot sha256 a VCS ref (no single downloaded file to hash) — integrity is delegated to git verifying the checked-out tree against the pinned commit SHA.
# The release workflow updates this to the exact 40-character version-commit
# SHA before publishing. Do NOT revert to `#tag=` — the tag is mutable.
source=("$pkgname-$pkgver::git+https://github.com/TimP4w/HaloDaemon.git#commit=058e56219206034159ce12e64074e91ef06fe86f"
        "halod-plugins::git+https://github.com/TimP4w/HaloDaemon-plugins.git#commit=$plugin_commit")
sha256sums=('SKIP' 'SKIP')

prepare() {
    cd "$srcdir/$pkgname-$pkgver/src"
    export CARGO_HOME="$srcdir/cargo-home"
    # Fetch crates (incl. the `q565` git dependency, via git-fetch-with-cli)
    # while the network is available so build() can run --frozen.
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
    # cargo-about isn't in the Arch repos; build it hermetically so the release
    # build can generate THIRD_PARTY_LICENSES.txt (HALOD_REQUIRE_LICENSES=1).
    cargo install --locked --features cli --root "$srcdir/tools" cargo-about
}

build() {
    cd "$srcdir/$pkgname-$pkgver/src"
    export CARGO_HOME="$srcdir/cargo-home"
    export PATH="$srcdir/tools/bin:$PATH"
    export HALOD_REQUIRE_LICENSES=1
    export RUSTUP_TOOLCHAIN=stable
    cargo build --release --frozen -p halod-plugin-signing
    target/release/halod-plugin-signing verify "$srcdir/halod-plugins" \
        --trusted-key halodaemon-official-2026=tjbwm5X4f70e+soVNV1AfRyb/TtnEsNNl+93YMO6IhQ=
    target/release/halod-plugin-signing bundle "$srcdir/halod-plugins" \
        --commit "$plugin_commit" \
        --output official-plugins.bundle
    if [[ -f "$srcdir/halod-plugins/licenses.txt" ]]; then
        cp "$srcdir/halod-plugins/licenses.txt" plugin-licenses.txt
        export HALOD_OFFICIAL_PLUGIN_LICENSES="$PWD/plugin-licenses.txt"
    fi
    export HALOD_REQUIRE_PLUGIN_BUNDLE=1
    export HALOD_OFFICIAL_PLUGIN_BUNDLE="$PWD/official-plugins.bundle"
    cargo build --release --frozen -p halod -p halod-gui
}

package() {
    cd "$srcdir/$pkgname-$pkgver"
    install -Dm755 src/target/release/halod     "$pkgdir/usr/bin/halod"
    install -Dm755 src/target/release/halod-gui "$pkgdir/usr/bin/halod-gui"
    install -Dm444 udev/60-halod.rules \
        "$pkgdir/usr/lib/udev/rules.d/60-halod.rules"
    install -Dm444 assets/dev.timp4w.Halod.desktop \
        "$pkgdir/usr/share/applications/dev.timp4w.Halod.desktop"
    install -Dm444 assets/icon.svg \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/halod.svg"
    install -Dm644 packaging/systemd/halod.service \
        "$pkgdir/usr/lib/systemd/user/halod.service"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    if [[ -f src/plugin-licenses.txt ]]; then
        install -Dm644 src/plugin-licenses.txt \
            "$pkgdir/usr/share/licenses/$pkgname/plugins/licenses.txt"
    fi
    install -Dm644 "$srcdir/halod-plugins/REUSE.toml" \
        "$pkgdir/usr/share/licenses/$pkgname/plugins/REUSE.toml"
    for license in "$srcdir"/halod-plugins/LICENSES/*; do
        install -Dm644 "$license" \
            "$pkgdir/usr/share/licenses/$pkgname/plugins/$(basename "$license")"
    done
}
